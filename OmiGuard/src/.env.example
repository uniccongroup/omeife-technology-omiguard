# Copy this file to .env in the same folder and fill in real values.

HF_TOKEN=your_hugging_face_token_here

# Optional email alerts for Caution and Dangerous predictions.
# Gmail SMTP can be used for free with a Gmail App Password.
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_alert_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_USE_SSL=false
ALERT_FROM_NAME=OmiGuard Alerts
ALERT_FROM_EMAIL=your_alert_gmail@gmail.com
ALERT_TO_EMAIL=recipient@example.com
ALERT_EMAIL_COOLDOWN_MINUTES=30
ALERT_DASHBOARD_URL=http://127.0.0.1:5500
